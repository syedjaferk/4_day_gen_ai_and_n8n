        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        112,
        192
      ],
      "id": "9d8ea018-794d-431e-88af-9cf139247abf",
      "name": "Groq Chat Model",
      "credentials": {
        "groqApi": {
          "id": "cH4SuiRy7O3qvWHP",
          "name": "SJ Groq Account"
        }
      }
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "={\n  \"category\":  {{ $json.output.parseJson().category }},\n  \"amount\": {{ $json.output.parseJson().amount }},\n  \"description\": {{ $json.output.parseJson().description }},\n  \"date\": {{ $json.output.parseJson().date }},\n  \"day\": {{ $json.output.parseJson().day }}\n}\n",
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
